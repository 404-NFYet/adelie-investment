{
  "id": null,
  "uid": "adelie-dev-api",
  "title": "Adelie Dev - Backend API",
  "tags": [
    "dev",
    "backend",
    "fastapi"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP RPS",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m]))",
          "legendFormat": "rps",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP 4xx/5xx",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"4..\"}[1m]))",
          "legendFormat": "4xx",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[1m]))",
          "legendFormat": "5xx",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency p50/p95/p99 (s)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_highr_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_highr_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_highr_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Requests In Progress",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "http_requests_inprogress",
          "legendFormat": "inprogress",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Auth Login/Refresh (cumulative)",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "auth_login_total",
          "legendFormat": "login {{result}}",
          "refId": "A"
        },
        {
          "expr": "auth_refresh_total",
          "legendFormat": "refresh {{result}}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Auth Register/Logout (cumulative)",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "expr": "auth_register_total",
          "legendFormat": "register {{result}}",
          "refId": "A"
        },
        {
          "expr": "auth_logout_total",
          "legendFormat": "logout {{result}}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Pipeline Jobs (rate)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 32
      },
      "targets": [
        {
          "expr": "sum(rate(pipeline_job_total[5m])) by (type, result)",
          "legendFormat": "{{type}} {{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Trading Orders (rate)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 32
      },
      "targets": [
        {
          "expr": "sum(rate(trading_order_total[5m])) by (side, result)",
          "legendFormat": "{{side}} {{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Portfolio Refresh (rate)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 40
      },
      "targets": [
        {
          "expr": "sum(rate(portfolio_refresh_total[5m])) by (result)",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tutor Chat (rate)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 40
      },
      "targets": [
        {
          "expr": "sum(rate(tutor_chat_total[5m])) by (result)",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tutor Tokens (rate)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 48
      },
      "targets": [
        {
          "expr": "sum(rate(tutor_chat_tokens_total[5m])) by (model)",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Briefing Today (rate)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 48
      },
      "targets": [
        {
          "expr": "sum(rate(briefing_today_total[5m])) by (result)",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Quiz Reward (rate)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 56
      },
      "targets": [
        {
          "expr": "sum(rate(quiz_reward_total[5m])) by (result)",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cache Hits/Misses (rate)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 56
      },
      "targets": [
        {
          "expr": "sum(rate(cache_hit_total[5m])) by (cache, hit)",
          "legendFormat": "{{cache}} {{hit}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "External API Requests (rate)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 64
      },
      "targets": [
        {
          "expr": "sum(rate(external_api_request_total[5m])) by (provider, result)",
          "legendFormat": "{{provider}} {{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "External API Latency p95 (s)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 64
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(external_api_latency_seconds_bucket[5m])) by (le, provider))",
          "legendFormat": "{{provider}} p95",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "DB Queries (rate)",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 72
      },
      "targets": [
        {
          "expr": "sum(rate(db_query_total[5m])) by (operation, result)",
          "legendFormat": "{{operation}} {{result}}",
          "refId": "A"
        }
      ]
    }
  ]
}
